# Supabase Configuration
# Get these values from your Supabase project dashboard at https://supabase.com

# Your Supabase project URL
# Example: https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_URL=your_supabase_url_here

# Your Supabase anon (public) key - NEVER use the service_role key in client code!
# Get this from: Supabase Dashboard > Settings > API > Project API Keys > anon key
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_key_here

# Optional: Project ID (can be derived from URL but useful for reference)
VITE_SUPABASE_PROJECT_ID=your_project_id_here

# ⚠️ SECURITY NOTES:
# 1. Never commit the actual .env file to git - it's in .gitignore
# 2. The values here are PUBLIC (anon) keys - they are safe to expose
# 3. Keep the service_role key SECRET - never put it in client-side code
# 4. Always use different credentials for development and production
# 5. Rotate your keys regularly (every 90 days is recommended)
